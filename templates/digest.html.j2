<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ digest.date }} 포스트마켓 다이제스트 · k-ant-daily</title>
<meta name="robots" content="noindex">
<style>
  {% include '_theme.css.j2' %}
  body { font-family: -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", sans-serif;
    background: var(--bg); color: var(--fg); margin: 0; line-height: 1.6; }
  .wrap { max-width: 820px; margin: 0 auto; padding: 20px 16px 80px; }
  header.top { display: flex; flex-wrap: wrap; align-items: baseline; gap: 10px;
    padding-bottom: 12px; border-bottom: 1px solid var(--border); margin-bottom: 18px; }
  header.top h1 { font-size: 20px; margin: 0; }
  header.top .meta { font-size: 12px; color: var(--muted); }
  header.top a.calendar-link { margin-left: auto; font-size: 13px; color: var(--accent); text-decoration: none; }
  h2 { font-size: 16px; margin: 24px 0 10px; }
  .section { background: var(--card); border-radius: 8px; padding: 14px 16px; margin-bottom: 14px; }
  .section h3 { margin: 0 0 8px; font-size: 14px; color: var(--accent); }
  .section ul { margin: 0; padding-left: 18px; }
  .section li { margin: 4px 0; font-size: 14px; }
  .highlights { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 10px; }
  .hl { border: 1px solid var(--border); border-radius: 6px; padding: 10px 12px; background: var(--bg); }
  .hl .kind { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .hl .title { font-weight: 600; font-size: 13px; margin: 4px 0 2px; }
  .hl .detail { font-size: 12px; color: var(--muted); }
  .hl a { color: var(--accent); font-size: 11px; text-decoration: none; }
  .upcoming ul { list-style: none; padding: 0; margin: 0; }
  .upcoming li { display: flex; gap: 12px; padding: 4px 0; border-bottom: 1px dashed var(--border); font-size: 13px; }
  .upcoming li:last-child { border-bottom: none; }
  .upcoming .when { color: var(--muted); flex: 0 0 90px; font-feature-settings: "tnum"; }
  footer { margin-top: 32px; text-align: center; color: var(--muted); font-size: 11px; }
</style>
</head>
<body>
<div class="wrap">

  <header class="top">
    <h1>포스트마켓 다이제스트</h1>
    <span class="meta">{{ digest.date }} · {{ digest.generated_label }}</span>
    <a class="calendar-link" href="calendar.html">캘린더 보기 →</a>
  </header>

  {%- if digest.tldr %}
  <div class="section">
    <h3>한 줄 요약</h3>
    <p style="margin:0; font-size:14px;">{{ digest.tldr }}</p>
  </div>
  {%- endif %}

  {%- for sec in digest.sections %}
  <div class="section">
    <h3>{{ sec.heading }}</h3>
    {%- if sec.bullets %}
    <ul>
      {%- for b in sec.bullets %}<li>{{ b }}</li>{%- endfor %}
    </ul>
    {%- endif %}
    {%- if sec.body %}
    <div style="font-size:14px; white-space:pre-wrap;">{{ sec.body }}</div>
    {%- endif %}
  </div>
  {%- endfor %}

  {%- if digest.highlights %}
  <h2>주요 헤드라인</h2>
  <div class="highlights">
    {%- for h in digest.highlights %}
    <div class="hl">
      {%- if h.kind %}<div class="kind">{{ h.kind }}</div>{%- endif %}
      <div class="title">{{ h.title }}</div>
      {%- if h.detail %}<div class="detail">{{ h.detail }}</div>{%- endif %}
      {%- if h.url %}<a href="{{ h.url }}" target="_blank" rel="noopener">원문 →</a>{%- endif %}
    </div>
    {%- endfor %}
  </div>
  {%- endif %}

  {%- if digest.upcoming %}
  <h2>내일 / 이번 주 주목</h2>
  <div class="section upcoming">
    <ul>
      {%- for u in digest.upcoming %}
      <li><span class="when">{{ u.date }}</span><span>{{ u.title }}{% if u.category %} <small style="color:var(--muted)">({{ u.category }})</small>{% endif %}</span></li>
      {%- endfor %}
    </ul>
  </div>
  {%- endif %}

  <footer>
    {{ digest.generated_label }} · <a href="calendar.html" style="color:var(--muted)">캘린더</a>
  </footer>
</div>
</body>
</html>
