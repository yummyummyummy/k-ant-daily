<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ date }} 장전 브리핑 · k-ant-daily</title>
<meta name="description" content="{{ tldr }}">
<link rel="canonical" href="{{ canonical_url }}">

<meta property="og:type" content="article">
<meta property="og:title" content="{{ date }} 장전 브리핑">
<meta property="og:description" content="{{ tldr }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:locale" content="ko_KR">
<meta property="og:site_name" content="k-ant-daily">
<meta property="article:published_time" content="{{ generated_at }}">

<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="{{ date }} 장전 브리핑">
<meta name="twitter:description" content="{{ tldr }}">

<style>
  :root {
    --fg: #0f172a;
    --muted: #64748b;
    --bg: #ffffff;
    --accent: #0f766e;
    --border: #e2e8f0;
    --card: #f8fafc;
    --pos: #dc2626;        /* 한국 주식 관행: 상승=빨강 */
    --pos-bg: rgba(220,38,38,0.08);
    --neg: #2563eb;        /* 하락=파랑 */
    --neg-bg: rgba(37,99,235,0.08);
    --neu: #6b7280;
    --neu-bg: rgba(107,114,128,0.08);
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --fg: #e2e8f0; --muted: #94a3b8; --bg: #0f172a; --accent: #5eead4;
      --border: #1e293b; --card: #1e293b;
      --pos: #f87171; --pos-bg: rgba(248,113,113,0.12);
      --neg: #60a5fa; --neg-bg: rgba(96,165,250,0.12);
      --neu: #94a3b8; --neu-bg: rgba(148,163,184,0.12);
    }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg); }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo",
      "Pretendard", "Noto Sans KR", sans-serif;
    line-height: 1.6; font-size: 16px;
    -webkit-text-size-adjust: 100%;
  }
  main { max-width: 720px; margin: 0 auto; padding: 24px 20px 64px; }

  /* TICKER STRIP (marquee) — above everything, below browser chrome. */
  .ticker-strip {
    position: sticky; top: 0; z-index: 50;
    overflow: hidden;
    background: var(--card);
    border-bottom: 1px solid var(--border);
    padding: 6px 0;
    font-variant-numeric: tabular-nums;
  }
  .ticker-track {
    display: inline-flex; gap: 36px; align-items: baseline;
    white-space: nowrap;
    width: max-content; padding-left: 36px;
    animation: ticker-scroll 60s linear infinite;
    will-change: transform;
  }
  .ticker-strip:hover .ticker-track,
  .ticker-strip:active .ticker-track { animation-play-state: paused; }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none; }
  }
  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .ticker-item { display: inline-flex; gap: 6px; align-items: baseline; font-size: 13px; }
  .ticker-item .name {
    color: var(--muted); font-weight: 700; font-size: 11px;
    letter-spacing: 0.05em; text-transform: uppercase;
  }
  .ticker-item .value { color: var(--fg); font-weight: 700; }
  .ticker-item .delta { font-weight: 600; }
  .ticker-item .delta.up   { color: var(--pos); }
  .ticker-item .delta.down { color: var(--neg); }
  .ticker-item .delta.flat { color: var(--muted); }
  .ticker-item .delta .pct { font-size: 11px; margin-left: 3px; opacity: 0.85; }

  header { border-bottom: 1px solid var(--border); padding-bottom: 16px; margin-bottom: 24px; }
  header h1 { font-size: 24px; margin: 0 0 8px; letter-spacing: -0.01em; }
  header .tldr { margin: 0; color: var(--fg); font-size: 17px; font-weight: 500; }
  header time { display: block; color: var(--muted); font-size: 13px; margin-top: 8px; }

  section { margin-bottom: 32px; }
  section > h2 { font-size: 18px; margin: 0 0 12px; display: flex; align-items: center; gap: 8px; }

  /* MOOD DASHBOARD — 5-axis grid above top stories */
  .mood-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 8px; margin: 12px 0 16px;
  }
  .mood-cell {
    padding: 10px 12px; border-radius: 8px;
    background: var(--bg); border: 1px solid var(--border);
    border-left: 3px solid var(--muted);
  }
  .mood-cell.positive { border-left-color: var(--pos); }
  .mood-cell.negative { border-left-color: var(--neg); }
  .mood-cell.neutral  { border-left-color: var(--muted); }
  .mood-cell .mood-head {
    display: flex; align-items: center; justify-content: space-between; gap: 6px;
    font-size: 11px; font-weight: 700;
  }
  .mood-cell .mood-axis { color: var(--muted); letter-spacing: 0.02em; }
  .mood-cell .mood-badge {
    font-weight: 700; padding: 1px 8px; border-radius: 999px; white-space: nowrap;
  }
  .mood-cell.positive .mood-badge { color: var(--pos); background: var(--pos-bg); }
  .mood-cell.negative .mood-badge { color: var(--neg); background: var(--neg-bg); }
  .mood-cell.neutral  .mood-badge { color: var(--muted); background: var(--neu-bg); }
  .mood-cell .mood-note { font-size: 13px; color: var(--fg); margin-top: 3px; line-height: 1.4; }

  /* TOP STORIES */
  .top-stories {
    background: linear-gradient(135deg, var(--card), transparent);
    border: 1px solid var(--border); border-left: 4px solid var(--accent);
    border-radius: 12px; padding: 16px 18px; margin-bottom: 24px;
  }
  .top-stories .cat-tag {
    display: inline-block; font-size: 10px; font-weight: 700;
    padding: 2px 6px; border-radius: 4px;
    background: var(--bg); color: var(--muted);
    border: 1px solid var(--border); margin-right: 4px;
    letter-spacing: 0.02em; white-space: nowrap;
  }
  .top-stories-more > summary {
    list-style: none; cursor: pointer; user-select: none; padding: 6px 0;
    font-size: 13px; font-weight: 600; color: var(--accent);
    display: inline-flex; align-items: center; gap: 4px; margin-top: 4px;
  }
  .top-stories-more > summary::-webkit-details-marker { display: none; }
  .top-stories-more > summary::after { content: "▾"; font-size: 10px; }
  .top-stories-more[open] > summary::after { content: "▴"; }
  .top-stories-more ol { padding-top: 4px; }

  /* FOCUS (geopolitics / hot topic) */
  .focus {
    background: var(--neg-bg);
    border: 1px solid var(--neg); border-left: 4px solid var(--neg);
    border-radius: 12px; padding: 16px 18px; margin-bottom: 24px;
  }
  .focus h2 { margin-top: 0; }
  .focus .focus-summary { margin: 0 0 8px; font-size: 15px; }
  .focus-status {
    display: flex; flex-wrap: wrap; align-items: center; gap: 8px 12px;
    padding: 10px 12px; margin: 0 0 12px;
    background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
  }
  .status-badge {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 13px; font-weight: 700; padding: 4px 12px;
    border-radius: 999px; letter-spacing: 0.02em;
  }
  .status-badge.closed      { background: #dc2626; color: white; }
  .status-badge.restricted  { background: #f59e0b; color: white; }
  .status-badge.open        { background: #16a34a; color: white; }
  @media (prefers-color-scheme: dark) {
    .status-badge.closed     { background: #b91c1c; }
    .status-badge.restricted { background: #d97706; }
    .status-badge.open       { background: #15803d; }
  }
  .status-detail { font-size: 13px; color: var(--muted); }
  .ship-count   { font-size: 13px; color: var(--fg); }
  .ship-count strong { font-size: 15px; color: var(--accent); }

  .news-items { list-style: none; padding: 0; margin: 8px 0 0; }
  .news-items li {
    padding: 10px 0; border-bottom: 1px solid var(--border);
  }
  .news-items li:last-child { border-bottom: none; }
  .news-items .headline { font-weight: 600; display: flex; align-items: flex-start; gap: 8px; flex-wrap: wrap; }
  .news-items .headline a { color: var(--fg); text-decoration: none; flex: 1; min-width: 0; }
  .news-items .headline a:hover { color: var(--accent); }
  .news-items .meta { font-size: 12px; color: var(--muted); margin-top: 3px; }
  .news-items .meta .dot { margin: 0 6px; }
  .news-items .time-ago { color: var(--accent); font-weight: 600; }
  .news-items .summary { font-size: 14px; color: var(--muted); margin-top: 4px; }

  /* REVIEW BANNER (evening) */
  .review-banner {
    border-radius: 12px; padding: 14px 18px; margin-bottom: 20px;
    background: linear-gradient(135deg, var(--card), transparent);
    border: 1px solid var(--border); border-left: 4px solid var(--accent);
  }
  .review-banner .rv-title { font-size: 13px; font-weight: 700; color: var(--muted); letter-spacing: 0.02em; }
  .review-banner .rv-score { font-size: 22px; font-weight: 800; margin-top: 2px; font-variant-numeric: tabular-nums; }
  .review-banner .rv-score .pct { color: var(--accent); }
  .review-banner .rv-sub { font-size: 13px; color: var(--muted); margin-top: 4px; }
  .review-banner .rv-breakdown { display: flex; flex-wrap: wrap; gap: 6px 14px; margin-top: 10px; font-size: 12px; }
  .review-banner .rv-chip { padding: 3px 10px; border-radius: 999px; font-weight: 600; }
  .review-banner .rv-chip.hit     { background: var(--pos-bg); color: var(--pos); }
  .review-banner .rv-chip.partial { background: rgba(245,158,11,0.15); color: #d97706; }
  .review-banner .rv-chip.miss    { background: var(--neg-bg); color: var(--neg); }
  .review-banner .rv-chip.neutral { background: var(--neu-bg); color: var(--muted); }
  .review-banner .rv-attrib { font-size: 12px; color: var(--muted); margin-top: 8px; }

  /* OUTCOME BADGE on stock-card summary row */
  .outcome-badge {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 4px;
    font-variant-numeric: tabular-nums;
  }
  .outcome-badge.hit     { background: var(--pos-bg); color: var(--pos); }
  .outcome-badge.partial { background: rgba(245,158,11,0.15); color: #d97706; }
  .outcome-badge.miss    { background: var(--neg-bg); color: var(--neg); }
  .outcome-badge.na      { background: var(--neu-bg); color: var(--muted); }

  /* SESSION RESULT block (inside expanded stock body) */
  .session-result-block {
    background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
    padding: 10px 12px; margin: 8px 0 10px; font-size: 13px;
  }
  .session-result-block .sr-head {
    font-size: 11px; font-weight: 700; color: var(--muted); letter-spacing: 0.05em;
    text-transform: uppercase; margin-bottom: 6px;
  }
  .session-result-block .sr-row {
    display: flex; flex-wrap: wrap; gap: 6px 10px; align-items: baseline; margin: 3px 0;
  }
  .session-result-block .sr-arrow { color: var(--muted); font-size: 13px; }
  .session-result-block .sr-note {
    margin-top: 6px; padding-top: 6px; border-top: 1px dashed var(--border);
    color: var(--fg); font-style: italic; font-size: 13px;
  }

  /* COFFEE BANNER */
  .coffee-banner {
    background: linear-gradient(135deg, #fde68a 0%, #fbbf24 100%);
    color: #422006;
    border-radius: 12px; padding: 14px 18px; margin-bottom: 20px;
    font-size: 15px;
  }
  @media (prefers-color-scheme: dark) {
    .coffee-banner { background: linear-gradient(135deg, #78350f 0%, #92400e 100%); color: #fef3c7; }
  }
  .coffee-banner .headline { font-weight: 700; font-size: 17px; margin-bottom: 4px; }
  .coffee-banner .headline { font-weight: 700; font-size: 15px; margin-bottom: 2px; }
  .coffee-banner .sub { font-size: 12px; opacity: 0.85; }
  .coffee-banner.none { background: var(--card); color: var(--fg); border: 1px dashed var(--border); }
  /* Compact 2-column card: [name + owners] | [price + delta] */
  .friend-cards {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 4px; margin-top: 8px;
  }
  .friend-card {
    background: rgba(255,255,255,0.55); border-radius: 6px;
    padding: 6px 10px;
    display: grid; grid-template-columns: 1fr auto; column-gap: 10px;
    align-items: center; min-width: 0;
  }
  @media (prefers-color-scheme: dark) {
    .friend-card { background: rgba(0,0,0,0.25); }
  }
  .coffee-banner.none .friend-card { background: var(--bg); border: 1px solid var(--border); }
  .friend-card .stock-name {
    grid-column: 1; grid-row: 1;
    font-size: 13px; font-weight: 700;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;
  }
  .friend-card .quote {
    grid-column: 2; grid-row: 1 / span 2;
    text-align: right;
    display: flex; flex-direction: column; gap: 0;
    font-variant-numeric: tabular-nums;
  }
  .friend-card .quote .price {
    font-size: 15px; font-weight: 800; line-height: 1.1;
  }
  .friend-card .quote .deltas {
    display: flex; gap: 5px; justify-content: flex-end; align-items: baseline; font-weight: 700;
  }
  .friend-card .quote .abs { font-size: 11px; }
  .friend-card .quote .pct { font-size: 11px; }
  .friend-card .quote.up   .price,
  .friend-card .quote.up   .abs,
  .friend-card .quote.up   .pct   { color: var(--pos); }
  .friend-card .quote.down .price,
  .friend-card .quote.down .abs,
  .friend-card .quote.down .pct   { color: var(--neg); }
  .friend-card .quote.flat .price { color: var(--fg); }
  .friend-card .quote.flat .abs,
  .friend-card .quote.flat .pct   { color: var(--muted); }
  @keyframes flash-up   { 0% { background: rgba(220,38,38,0.35); } 100% { background: transparent; } }
  @keyframes flash-down { 0% { background: rgba(37,99,235,0.35); } 100% { background: transparent; } }
  .friend-card .price.flash-up   { animation: flash-up 0.8s ease-out; border-radius: 4px; }
  .friend-card .price.flash-down { animation: flash-down 0.8s ease-out; border-radius: 4px; }

  /* LIVE INDICATOR */
  .live-indicator {
    font-size: 11px; color: var(--muted); margin-top: 8px; text-align: right;
    opacity: 0.85;
  }
  .live-indicator.live   { color: var(--accent); }
  .live-indicator.closed { opacity: 0.6; }
  .live-indicator.error  { color: var(--neg); }
  .friend-card .owners {
    grid-column: 1; grid-row: 2;
    position: relative;
    display: flex; flex-wrap: wrap; gap: 2px; margin-top: 1px; min-width: 0;
  }
  .friend-card .owner-chip {
    font-size: 9px; font-weight: 700;
    background: rgba(0,0,0,0.1); border-radius: 999px;
    padding: 1px 5px; white-space: nowrap;
  }
  @media (prefers-color-scheme: dark) {
    .friend-card .owner-chip { background: rgba(255,255,255,0.12); }
  }

  /* Owner popover — applies to both coffee friend-cards and stock-card rows */
  .owners-wrap {
    position: relative;
    display: inline-flex; gap: 2px; align-items: center;
  }
  .owners-wrap .owner-more {
    cursor: pointer; opacity: 0.75;
    background: rgba(0,0,0,0.06);
  }
  @media (prefers-color-scheme: dark) {
    .owners-wrap .owner-more { background: rgba(255,255,255,0.08); }
  }
  .owner-popover {
    display: none;
    position: absolute; top: calc(100% + 4px); right: 0;
    z-index: 100;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 6px; padding: 6px;
    gap: 3px; flex-wrap: wrap; min-width: 120px; max-width: 220px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
  }
  @media (hover: hover) {
    .owners-wrap:hover .owner-popover { display: flex; }
  }
  .owners-wrap:focus-within .owner-popover,
  .owners-wrap.open .owner-popover { display: flex; }

  /* MACRO / SECTOR collapse toggle (reuses focus-toggle styling) */
  .section-toggle > summary {
    list-style: none; cursor: pointer; user-select: none;
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 600; color: var(--accent);
    background: var(--card); border: 1px solid var(--border); border-radius: 999px;
    padding: 4px 12px; margin-top: 4px;
  }
  .section-toggle > summary::-webkit-details-marker { display: none; }
  .section-toggle > summary::after { content: "▾"; font-size: 10px; }
  .section-toggle[open] > summary::after { content: "▴"; }
  .section-toggle .section-body { padding-top: 12px; }

  /* SECTOR toggle — wider, fills the row */
  .sector-toggle > summary {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    width: 100%; padding: 10px 14px; cursor: pointer; user-select: none;
    background: var(--card); border: 1px solid var(--border); border-radius: 8px;
    color: var(--fg); font-size: 14px; list-style: none;
  }
  .sector-toggle > summary::-webkit-details-marker { display: none; }
  .sector-toggle > summary::after { content: "▾"; font-size: 11px; color: var(--muted); margin-left: auto; }
  .sector-toggle[open] > summary::after { content: "▴"; }
  .sector-toggle > summary .sector-name { font-weight: 600; }
  .sector-toggle .section-body { padding: 10px 14px 2px; }

  /* STOCK CARD overnight signal badge */
  .overnight-badge {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.02em;
    padding: 2px 8px; border-radius: 4px;
    font-variant-numeric: tabular-nums;
  }
  .overnight-badge.up       { color: var(--pos); background: var(--pos-bg); }
  .overnight-badge.down     { color: var(--neg); background: var(--neg-bg); }
  .overnight-badge.neutral  { color: var(--muted); background: var(--neu-bg); }

  /* DECISION SIGNALS block (inside expanded stock body) */
  .decision-block {
    background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
    padding: 10px 12px; margin: 8px 0 10px; font-size: 13px;
  }
  .decision-block .row { display: flex; flex-wrap: wrap; gap: 6px 10px; align-items: baseline; margin: 3px 0; }
  .decision-block .label { font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; min-width: 82px; }
  .decision-block .value { font-weight: 600; }
  .decision-block .proxies { color: var(--muted); font-size: 12px; }
  .decision-block .proxies .p.up   { color: var(--pos); }
  .decision-block .proxies .p.down { color: var(--neg); }
  .decision-block .rationale { margin-top: 6px; padding-top: 6px; border-top: 1px dashed var(--border); color: var(--fg); font-style: italic; font-size: 13px; }
  .confidence-chip {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 999px;
    background: var(--card); color: var(--muted); border: 1px solid var(--border);
    margin-left: 4px;
  }
  .confidence-chip.high   { color: var(--accent); border-color: var(--accent); }
  .confidence-chip.medium { color: var(--fg); }
  .confidence-chip.low    { opacity: 0.65; }

  /* Price context block (sparkline + 52w range) inside expanded stock body */
  .price-context {
    background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
    padding: 10px 12px; margin: 8px 0 10px;
    display: grid; grid-template-columns: auto 1fr; gap: 12px 14px;
    align-items: center;
  }
  .price-context .spark-wrap {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
  }
  .price-context .spark {
    width: 90px; height: 28px; display: block;
  }
  .price-context .spark path { stroke-width: 1.5; fill: none; }
  .price-context .spark.up   path { stroke: var(--pos); }
  .price-context .spark.down path { stroke: var(--neg); }
  .price-context .spark.flat path { stroke: var(--muted); }
  .price-context .spark-label {
    font-size: 10px; color: var(--muted); font-variant-numeric: tabular-nums;
  }
  .price-context .spark-label .pos { color: var(--pos); font-weight: 600; }
  .price-context .spark-label .neg { color: var(--neg); font-weight: 600; }

  .price-context .w52 {
    display: flex; flex-direction: column; gap: 4px; min-width: 0;
  }
  .price-context .w52-bar {
    position: relative; height: 6px; border-radius: 3px;
    background: linear-gradient(to right, rgba(37,99,235,0.35), rgba(128,128,128,0.2), rgba(220,38,38,0.35));
  }
  .price-context .w52-pin {
    position: absolute; top: -3px; width: 3px; height: 12px;
    background: var(--fg); border-radius: 2px;
    transform: translateX(-50%);
  }
  .price-context .w52-labels {
    display: flex; justify-content: space-between; gap: 6px;
    font-size: 10px; color: var(--muted); font-variant-numeric: tabular-nums;
  }
  .price-context .w52-labels .mid {
    font-weight: 600; color: var(--fg);
  }

  /* Fresh-news counter on stock summary row (오늘 뉴스 N건) */
  .news-count-chip {
    display: inline-flex; align-items: center; gap: 2px;
    font-size: 10px; font-weight: 700;
    padding: 2px 6px; border-radius: 4px;
    background: rgba(245, 158, 11, 0.12); color: #d97706;
  }
  @media (prefers-color-scheme: dark) {
    .news-count-chip { background: rgba(245, 158, 11, 0.18); color: #fbbf24; }
  }

  /* Stock news block (inside expanded stock body) — trader's morning digest */
  .stock-news-block {
    margin: 10px 0 12px;
  }
  .stock-news-block > h4 {
    font-size: 12px; color: var(--muted); margin: 0 0 8px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .stock-news-block ul { list-style: none; padding: 0; margin: 0; }
  .stock-news-block li {
    display: flex; gap: 8px; padding: 6px 0;
    border-top: 1px dashed var(--border);
  }
  .stock-news-block li:first-child { border-top: none; padding-top: 0; }
  .stock-news-block .news-dot {
    flex-shrink: 0; width: 7px; height: 7px; border-radius: 50%;
    margin-top: 8px; background: var(--muted);
  }
  .stock-news-block .news-dot.positive { background: var(--pos); }
  .stock-news-block .news-dot.negative { background: var(--neg); }
  .stock-news-block .news-body { flex: 1; min-width: 0; }
  .stock-news-block .news-title { font-size: 13px; line-height: 1.4; }
  .stock-news-block .news-title a { color: var(--fg); text-decoration: none; }
  .stock-news-block .news-title a:hover { color: var(--accent); }
  .stock-news-block .news-meta {
    font-size: 11px; color: var(--muted); margin-top: 2px;
    display: flex; gap: 6px; flex-wrap: wrap;
  }
  .stock-news-block .news-meta .time-ago { color: var(--accent); font-weight: 600; }
  .stock-news-block .why-material,
  .sector-card .why-material {
    font-size: 12px; color: var(--accent); margin-top: 3px; line-height: 1.4;
    font-style: italic; opacity: 0.9;
  }
  .stock-news-block details.news-more > summary {
    list-style: none; cursor: pointer; user-select: none;
    font-size: 12px; font-weight: 600; color: var(--accent);
    padding: 6px 0 0; display: inline-flex; align-items: center; gap: 4px;
  }
  .stock-news-block details.news-more > summary::-webkit-details-marker { display: none; }
  .stock-news-block details.news-more > summary::after { content: "▾"; font-size: 10px; }
  .stock-news-block details.news-more[open] > summary::after { content: "▴"; }

  /* STOCK CARD owner chips (right-aligned on summary row) */
  article.stock > details > summary { position: relative; padding-right: 30px; }
  article.stock > details > summary::after { position: absolute; right: 12px; top: 14px; margin-left: 0; }
  article.stock .owner-chips {
    display: inline-flex; flex-wrap: wrap; gap: 3px; margin-left: auto;
  }
  article.stock .owner-chips .owner-chip {
    font-size: 10px; font-weight: 700; color: var(--accent);
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 999px; padding: 2px 8px; white-space: nowrap;
  }
  .top-stories h2 { margin-top: 0; }
  .top-stories ol { margin: 0; padding-left: 20px; }
  .top-stories li { padding: 6px 0; border-bottom: 1px dashed var(--border); }
  .top-stories li:last-child { border-bottom: none; }
  .top-stories details > summary {
    list-style: none; cursor: pointer; display: flex; align-items: center;
    gap: 6px; flex-wrap: wrap; user-select: none; padding: 4px 0;
  }
  .top-stories details > summary::-webkit-details-marker { display: none; }
  .top-stories details > summary::after {
    content: "자세히 ▾"; font-size: 11px; color: var(--accent);
    background: var(--bg); padding: 2px 8px; border-radius: 4px;
    border: 1px solid var(--border); margin-left: auto;
    white-space: nowrap; font-weight: 500;
  }
  .top-stories details[open] > summary::after { content: "접기 ▴"; }
  .top-stories .title { font-weight: 600; flex: 1; min-width: 0; }
  .top-stories .body { padding: 6px 0 4px; }
  .top-stories .why { color: var(--muted); font-size: 14px; margin-top: 2px; }
  .top-stories .sources { margin-top: 6px; display: flex; flex-wrap: wrap; gap: 6px; }
  .top-stories .sources a {
    font-size: 12px; color: var(--accent); text-decoration: none;
    background: var(--bg); padding: 2px 8px; border-radius: 4px; border: 1px solid var(--border);
  }

  /* FOCUS: collapsible details toggle */
  .focus-toggle { border: none; background: none; padding: 0; margin: 0; }
  .focus-toggle > summary {
    list-style: none; cursor: pointer; user-select: none;
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600; color: var(--accent);
    background: var(--bg); border: 1px solid var(--border); border-radius: 999px;
    padding: 6px 14px; margin-top: 4px;
  }
  .focus-toggle > summary::-webkit-details-marker { display: none; }
  .focus-toggle > summary::after { content: "▾"; font-size: 11px; }
  .focus-toggle[open] > summary::after { content: "▴"; }
  .focus-toggle .focus-body { padding-top: 12px; }

  /* IMPACT BADGES */
  .impact { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 4px; font-weight: 600; vertical-align: middle; margin-left: 6px; }
  .impact.positive { background: var(--pos-bg); color: var(--pos); }
  .impact.negative { background: var(--neg-bg); color: var(--neg); }
  .impact.neutral { background: var(--neu-bg); color: var(--neu); }

  /* INDICATORS */
  .indicators { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 8px; margin-bottom: 12px; }
  .indicator { padding: 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--card); position: relative; }
  .indicator.positive { border-left: 3px solid var(--pos); background: linear-gradient(to right, var(--pos-bg), var(--card) 60%); }
  .indicator.negative { border-left: 3px solid var(--neg); background: linear-gradient(to right, var(--neg-bg), var(--card) 60%); }
  .indicator.neutral { border-left: 3px solid var(--neu); }
  .indicator .name { font-size: 12px; color: var(--muted); margin-bottom: 4px; }
  .indicator .value { font-size: 16px; font-weight: 600; }
  .indicator .change { font-size: 13px; margin-top: 2px; font-weight: 500; font-variant-numeric: tabular-nums; }
  .indicator .change.up { color: var(--pos); }
  .indicator .change.down { color: var(--neg); }
  .indicator .arrow { font-size: 11px; margin-right: 2px; }
  .indicator .change .pct { font-size: 11px; opacity: 0.75; margin-left: 4px; font-weight: 500; }
  .indicator .change .abs { font-weight: 600; }
  .section-sub { font-size: 14px; color: var(--muted); margin: -4px 0 8px; }

  /* KEY POINTS */
  .summary { color: var(--fg); }
  .macro-mood {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; padding: 4px 10px; border-radius: 999px; font-weight: 500;
    margin-left: 8px;
  }
  .macro-mood.positive { background: var(--pos-bg); color: var(--pos); }
  .macro-mood.negative { background: var(--neg-bg); color: var(--neg); }
  .macro-mood.neutral { background: var(--neu-bg); color: var(--neu); }

  .points { list-style: none; padding: 0; margin: 0; }
  .points li { padding: 12px 0; border-bottom: 1px solid var(--border); }
  .points li:last-child { border-bottom: none; }
  .points .point-title { font-weight: 600; margin-bottom: 4px; display: flex; align-items: flex-start; gap: 8px; flex-wrap: wrap; }
  .points .point-title .text { flex: 1; min-width: 0; }
  .points .point-title .time-ago { font-size: 11px; color: var(--accent); font-weight: 600; white-space: nowrap; }
  .points .point-detail { color: var(--muted); font-size: 14px; margin: 4px 0; }
  .points .sources { margin-top: 6px; display: flex; flex-wrap: wrap; gap: 6px; }
  .points .sources a {
    font-size: 12px; color: var(--accent); text-decoration: none;
    background: var(--card); padding: 2px 8px; border-radius: 4px; border: 1px solid var(--border);
  }
  .points .sources a:hover { text-decoration: underline; }

  /* STOCK CARD */
  article.stock { background: var(--card); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 10px; overflow: hidden; }
  article.stock > details > summary {
    list-style: none; cursor: pointer; padding: 14px 16px;
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    user-select: none;
  }
  article.stock > details > summary::-webkit-details-marker { display: none; }
  article.stock > details > summary::after {
    content: "▸"; color: var(--muted); font-size: 14px; margin-left: auto; transition: transform 0.15s;
  }
  article.stock > details[open] > summary::after { transform: rotate(90deg); }
  article.stock > details[open] > summary { border-bottom: 1px solid var(--border); }
  article.stock .body { padding: 12px 16px 16px; }
  article.stock .owner-tag {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 12px; font-weight: 700; color: var(--accent);
    background: var(--bg); padding: 3px 8px; border-radius: 999px;
    border: 1px solid var(--border);
  }
  article.stock .name { font-size: 16px; font-weight: 600; }
  article.stock .code { font-size: 11px; color: var(--muted); font-weight: 400; font-family: ui-monospace, SFMono-Regular, monospace; }
  article.stock .price-change {
    font-size: 15px; font-weight: 700; font-variant-numeric: tabular-nums;
    padding: 2px 8px; border-radius: 4px;
  }
  article.stock .price-change.up { color: var(--pos); background: var(--pos-bg); }
  article.stock .price-change.down { color: var(--neg); background: var(--neg-bg); }
  article.stock .price-change.flat { color: var(--muted); background: var(--neu-bg); }
  article.stock header { border: none; padding: 0; margin: 0 0 8px; }
  article.stock h3 { margin: 0; font-size: 17px; display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }

  /* RECOMMENDATION BADGE (5 levels) */
  .rec {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 12px; font-weight: 700; padding: 3px 10px;
    border-radius: 999px; letter-spacing: 0.02em;
  }
  .rec.strong_buy { background: #dc2626; color: white; }
  .rec.buy { background: var(--pos-bg); color: var(--pos); border: 1px solid var(--pos); }
  .rec.hold { background: var(--neu-bg); color: var(--neu); border: 1px solid var(--neu); }
  .rec.sell { background: var(--neg-bg); color: var(--neg); border: 1px solid var(--neg); }
  .rec.strong_sell { background: #1d4ed8; color: white; }
  @media (prefers-color-scheme: dark) {
    .rec.strong_buy { background: #b91c1c; }
    .rec.strong_sell { background: #1e40af; }
  }
  .rec-rationale { color: var(--muted); font-size: 13px; margin-top: 6px; font-style: italic; }

  article.stock .stock-summary { margin: 8px 0 12px; }
  article.stock h4 { font-size: 12px; color: var(--muted); margin: 16px 0 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }

  /* DEEP DIVE */
  .deep-dive {
    background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
    padding: 12px 14px; margin-top: 12px; font-size: 14px;
  }
  .deep-dive h4 { margin-top: 0; }
  .deep-dive .dd-block { margin: 8px 0; }
  .deep-dive .dd-label { font-size: 11px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
  .deep-dive .dd-body { color: var(--fg); }
  .deep-dive .dd-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px; }
  .deep-dive .dd-tag { font-size: 11px; background: var(--card); padding: 2px 8px; border-radius: 4px; color: var(--muted); border: 1px solid var(--border); }

  .disclosures { list-style: none; padding: 0; margin: 0; }
  .disclosures li { font-size: 13px; padding: 6px 0; border-bottom: 1px dashed var(--border); }
  .disclosures li:last-child { border-bottom: none; }
  .disclosures a { color: var(--fg); text-decoration: none; }
  .disclosures a:hover { color: var(--accent); }
  .disclosures .date { color: var(--muted); font-size: 11px; margin-left: 6px; }

  .sector-tag { display: inline-block; font-size: 11px; background: var(--border); color: var(--muted); padding: 2px 6px; border-radius: 4px; margin-right: 4px; }

  /* SECTOR BRIEFING CARD (new news-centric layout) */
  .sector-card {
    background: var(--card); border: 1px solid var(--border);
    border-left: 3px solid var(--muted);
    border-radius: 10px; padding: 12px 14px; margin-bottom: 10px;
  }
  .sector-card.positive { border-left-color: var(--pos); }
  .sector-card.negative { border-left-color: var(--neg); }
  .sector-card.neutral  { border-left-color: var(--muted); }
  .sector-card .sec-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 8px; flex-wrap: wrap;
  }
  .sector-card .sec-title { font-size: 15px; font-weight: 700; display: flex; align-items: center; gap: 6px; }
  .sector-card .sec-emoji { font-size: 18px; }
  .sector-card .sec-headline {
    color: var(--fg); font-size: 13px; margin-top: 4px; line-height: 1.4;
  }
  .sector-card .sec-news {
    list-style: none; padding: 0; margin: 8px 0 0;
  }
  .sector-card .sec-news li {
    display: flex; gap: 8px; padding: 6px 0;
    border-top: 1px dashed var(--border);
  }
  .sector-card .sec-news li:first-child { border-top: none; padding-top: 8px; }
  .sector-card .news-dot {
    flex-shrink: 0; width: 8px; height: 8px; border-radius: 50%;
    margin-top: 7px; background: var(--muted);
  }
  .sector-card .news-dot.positive { background: var(--pos); }
  .sector-card .news-dot.negative { background: var(--neg); }
  .sector-card .news-body { flex: 1; min-width: 0; }
  .sector-card .news-title {
    font-size: 13px; font-weight: 500; line-height: 1.4;
  }
  .sector-card .news-title a { color: var(--fg); text-decoration: none; }
  .sector-card .news-title a:hover { color: var(--accent); }
  .sector-card .news-meta {
    font-size: 11px; color: var(--muted); margin-top: 2px;
    display: flex; gap: 6px; flex-wrap: wrap; align-items: baseline;
  }
  .sector-card .news-meta .time-ago { color: var(--accent); font-weight: 600; }
  .sector-card .news-note {
    font-size: 12px; color: var(--muted); margin-top: 3px; font-style: italic;
  }
  .sector-card details.sec-more > summary {
    list-style: none; cursor: pointer; user-select: none;
    font-size: 12px; font-weight: 600; color: var(--accent);
    padding: 4px 0 0; margin-top: 2px;
    display: inline-flex; align-items: center; gap: 4px;
  }
  .sector-card details.sec-more > summary::-webkit-details-marker { display: none; }
  .sector-card details.sec-more > summary::after { content: "▾"; font-size: 10px; }
  .sector-card details.sec-more[open] > summary::after { content: "▴"; }

  footer {
    margin-top: 48px; padding-top: 16px; border-top: 1px solid var(--border);
    color: var(--muted); font-size: 12px; text-align: center;
  }
  footer .disclaimer {
    background: var(--card); border: 1px solid var(--border); border-radius: 8px;
    padding: 10px 14px; margin-bottom: 10px; text-align: left;
  }
</style>
</head>
{#- Owner chips with collapsed "primary + (+N)" view and hover/tap popover.
    `owners` is expected to be sorted (leader first, then 가나다 순). -#}
{%- macro owner_chips(owners) -%}
  {%- set n = owners | length -%}
  {%- if n == 0 -%}
  {%- elif n == 1 -%}
    <span class="owners-wrap"><span class="owner-chip">👤 {{ owners[0] }}</span></span>
  {%- else -%}
    <span class="owners-wrap" tabindex="0">
      <span class="owner-chip">👤 {{ owners[0] }}</span>
      <span class="owner-chip owner-more" aria-label="+{{ n - 1 }}명 더 보기">+{{ n - 1 }}</span>
      <span class="owner-popover">
        {%- for o in owners -%}<span class="owner-chip">👤 {{ o }}</span>{%- endfor -%}
      </span>
    </span>
  {%- endif -%}
{%- endmacro -%}
<body data-date="{{ date }}">
{% if ticker %}
<div class="ticker-strip" id="ticker-strip">
  <div class="ticker-track">
    {% for _ in range(2) %}
      {% for t in ticker %}
      <span class="ticker-item" data-ticker="{{ t.key }}">
        <span class="name">{{ t.name }}</span>
        <span class="value">{{ t.value or '—' }}</span>
        {% if t.change_abs or t.change_pct %}
        <span class="delta {{ t.direction or 'flat' }}">
          {% if t.change_abs %}{{ t.change_abs }}{% endif %}
          {% if t.change_pct %}<span class="pct">{{ t.change_pct }}</span>{% endif %}
        </span>
        {% endif %}
      </span>
      {% endfor %}
    {% endfor %}
  </div>
</div>
{% endif %}
<main>
  <header>
    <h1>📰 {{ date }} 장전 브리핑</h1>
    <p class="tldr">{{ tldr }}</p>
    <time>생성: {{ generated_at_display }} KST · <a href="archive.html">아카이브</a></time>
  </header>

  {% if friends_overview %}
    {% if coffee_buyer %}
    <div class="coffee-banner">
      <div class="headline">☕ 오늘 커피는 <strong>{{ coffee_buyer.owners | join('·') }}</strong>님이!</div>
      <div class="sub">{{ coffee_buyer.name }} {{ coffee_buyer.change_display }} — 친구 보유 종목 중 최고 상승</div>
      <div class="friend-cards" id="friend-cards">
        {% for f in friends_overview %}
        <div class="friend-card" data-code="{{ f.code }}">
          <div class="stock-name">{{ f.name }}</div>
          <div class="quote {{ f.direction or 'flat' }}">
            <div class="price">{{ f.price_display or '-' }}</div>
            <div class="deltas">
              <span class="abs">{{ f.abs_change_display or '' }}</span>
              <span class="pct">{{ f.change_display }}</span>
            </div>
          </div>
          <div class="owners">{{ owner_chips(f.owners) }}</div>
        </div>
        {% endfor %}
      </div>
      <div class="live-indicator" id="live-indicator" aria-live="polite"></div>
    </div>
    {% else %}
    <div class="coffee-banner none">
      <div class="headline">☕ 오늘 커피는 각자 사기</div>
      <div class="sub">친구 보유 종목 중 상승 종목 없음</div>
      <div class="friend-cards" id="friend-cards">
        {% for f in friends_overview %}
        <div class="friend-card" data-code="{{ f.code }}">
          <div class="stock-name">{{ f.name }}</div>
          <div class="quote {{ f.direction or 'flat' }}">
            <div class="price">{{ f.price_display or '-' }}</div>
            <div class="deltas">
              <span class="abs">{{ f.abs_change_display or '' }}</span>
              <span class="pct">{{ f.change_display }}</span>
            </div>
          </div>
          <div class="owners">{{ owner_chips(f.owners) }}</div>
        </div>
        {% endfor %}
      </div>
      <div class="live-indicator" id="live-indicator" aria-live="polite"></div>
    </div>
    {% endif %}
  {% endif %}

  {% if review %}
  <section class="review-banner">
    <div class="rv-title">📊 오늘의 예측 검증 · NXT 마감 후</div>
    <div class="rv-score">
      {{ review.accuracy.hits }}/{{ review.accuracy.total }} 적중
      <span class="pct">· {{ (review.accuracy.hit_rate * 100) | round(0) | int }}%</span>
    </div>
    <div class="rv-sub">
      방향 정확도 {{ (review.accuracy.directional_accuracy * 100) | round(0) | int }}%
      {% if review.session_change.kospi %} · KOSPI {{ review.session_change.kospi }}{% endif %}
      {% if review.session_change.kosdaq %} · KOSDAQ {{ review.session_change.kosdaq }}{% endif %}
    </div>
    <div class="rv-breakdown">
      <span class="rv-chip hit">✅ 적중 {{ review.accuracy.hits }}</span>
      <span class="rv-chip partial">🟡 부분 {{ review.accuracy.partial }}</span>
      <span class="rv-chip miss">❌ 실패 {{ review.accuracy.misses }}</span>
      {% if review.accuracy.by_confidence %}
        {% for conf, stat in review.accuracy.by_confidence.items() %}
        <span class="rv-chip neutral">
          신뢰 {% if conf == 'high' %}높음{% elif conf == 'low' %}낮음{% else %}중간{% endif %}
          · {{ (stat.rate * 100) | round(0) | int }}% ({{ stat.hits }}/{{ stat.total }})
        </span>
        {% endfor %}
      {% endif %}
    </div>
    {% if review.signal_attribution %}
    <div class="rv-attrib">
      {% set a = review.signal_attribution %}
      신호 기여도 —
      {% if a.overnight_helped %}간밤 적중 {{ a.overnight_helped }}건 · {% endif %}
      {% if a.news_misread %}뉴스 오독 {{ a.news_misread }}건 · {% endif %}
      {% if a.overnight_misled %}간밤 오도 {{ a.overnight_misled }}건 · {% endif %}
      {% if a.priced_in_underestimated %}반영 과소추정 {{ a.priced_in_underestimated }}건{% endif %}
    </div>
    {% endif %}
  </section>
  {% endif %}

  {% if top_stories or mood_dashboard %}
  <section class="top-stories">
    <h2>
      ⭐ 오늘의 핵심
      {% if macro.overall_impact %}
      <span class="macro-mood {{ macro.overall_impact }}">
        {% if macro.overall_impact == 'positive' %}🟢 한국 증시에 우호적
        {% elif macro.overall_impact == 'negative' %}🔴 한국 증시에 부담
        {% else %}🟡 중립/혼조{% endif %}
      </span>
      {% endif %}
    </h2>
    {% if macro.summary %}<p class="point-detail" style="margin: -4px 0 12px; font-size: 14px;">{{ macro.summary }}</p>{% endif %}

    {% if mood_dashboard %}
    <div class="mood-grid">
      {% for axis in mood_axes %}
        {% set m = mood_dashboard.get(axis.key) %}
        {% if m %}
        <div class="mood-cell {{ m.impact or 'neutral' }}">
          <div class="mood-head">
            <span class="mood-axis">{{ axis.emoji }} {{ axis.name }}</span>
            <span class="mood-badge">
              {% if m.impact == 'positive' %}🟢 우호
              {% elif m.impact == 'negative' %}🔴 부담
              {% else %}🟡 혼조{% endif %}
            </span>
          </div>
          {% if m.note %}<div class="mood-note">{{ m.note }}</div>{% endif %}
        </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {% if top_stories %}
    {% set visible = top_stories[:3] %}
    {% set hidden = top_stories[3:] %}
    <ol>
      {% for ts in visible %}
      <li>
        <details>
          <summary>
            {% if ts.category %}<span class="cat-tag">{{ ts.category_label or ts.category }}</span>{% endif %}
            <span class="title">{{ ts.headline }}</span>
            {% if ts.impact %}<span class="impact {{ ts.impact }}">{{ ts.impact_label or ts.impact }}</span>{% endif %}
          </summary>
          <div class="body">
            {% if ts.why_it_matters %}<div class="why">{{ ts.why_it_matters }}</div>{% endif %}
            {% if ts.sources %}
            <div class="sources">
              {% for src in ts.sources %}<a href="{{ src.url }}" target="_blank" rel="noopener">{{ src.title }}</a>{% endfor %}
            </div>
            {% endif %}
          </div>
        </details>
      </li>
      {% endfor %}
    </ol>
    {% if hidden %}
    <details class="top-stories-more">
      <summary>더 보기 ({{ hidden|length }}개)</summary>
      <ol start="4">
        {% for ts in hidden %}
        <li>
          <details>
            <summary>
              {% if ts.category %}<span class="cat-tag">{{ ts.category_label or ts.category }}</span>{% endif %}
              <span class="title">{{ ts.headline }}</span>
              {% if ts.impact %}<span class="impact {{ ts.impact }}">{{ ts.impact_label or ts.impact }}</span>{% endif %}
            </summary>
            <div class="body">
              {% if ts.why_it_matters %}<div class="why">{{ ts.why_it_matters }}</div>{% endif %}
              {% if ts.sources %}
              <div class="sources">
                {% for src in ts.sources %}<a href="{{ src.url }}" target="_blank" rel="noopener">{{ src.title }}</a>{% endfor %}
              </div>
              {% endif %}
            </div>
          </details>
        </li>
        {% endfor %}
      </ol>
    </details>
    {% endif %}
    {% endif %}
  </section>
  {% endif %}

  {% if focus %}
  <section class="focus">
    <h2>
      🚨 {{ focus.title or '집중 이슈' }}
      {% if focus.impact %}<span class="impact {{ focus.impact }}">{{ focus.impact_label or focus.impact }}</span>{% endif %}
    </h2>
    {% if focus.status %}
    <div class="focus-status">
      {% if focus.status.level %}
      <span class="status-badge {{ focus.status.level }}">
        {% if focus.status.level == 'closed' %}🚫{% elif focus.status.level == 'restricted' %}⚠️{% elif focus.status.level == 'open' %}✅{% endif %}
        {{ focus.status.label or focus.status.level }}
      </span>
      {% endif %}
      {% if focus.status.detail %}<span class="status-detail">{{ focus.status.detail }}</span>{% endif %}
      {% if focus.status.ship_count %}
      <span class="ship-count">
        🚢 <strong>{{ focus.status.ship_count.value }}</strong>
        {% if focus.status.ship_count.date %}({{ focus.status.ship_count.date }}){% endif %}
        {% if focus.status.ship_count.note %} · {{ focus.status.ship_count.note }}{% endif %}
        {% if focus.status.ship_count.source %}
        <a href="{{ focus.status.ship_count.source.url }}" target="_blank" rel="noopener" style="color: var(--accent); margin-left: 4px;">({{ focus.status.ship_count.source.title }})</a>
        {% endif %}
      </span>
      {% endif %}
    </div>
    {% endif %}
    {% if focus.summary or focus.news_items %}
    <details class="focus-toggle">
      <summary>자세히 보기</summary>
      <div class="focus-body">
        {% if focus.summary %}<p class="focus-summary">{{ focus.summary }}</p>{% endif %}
        {% if focus.news_items %}
        <ul class="news-items">
          {% for n in focus.news_items %}
          <li>
            <div class="headline">
              <a href="{{ n.url }}" target="_blank" rel="noopener">{{ n.title }}</a>
              {% if n.impact %}<span class="impact {{ n.impact }}">{{ n.impact_label or n.impact }}</span>{% endif %}
            </div>
            <div class="meta">
              {% if n.time_ago %}<span class="time-ago">{{ n.time_ago }}</span>{% endif %}
              {% if n.source %}<span class="dot">·</span>{{ n.source }}{% endif %}
            </div>
            {% if n.summary %}<div class="summary">{{ n.summary }}</div>{% endif %}
          </li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
    </details>
    {% endif %}
  </section>
  {% endif %}

  {# 📊 국내 시장 지표 was folded into the top ticker marquee (KOSPI / KOSDAQ / USD/KRW).
     KOSPI200 and JPY·EUR·CNY weren't pulling enough weight to justify a full section. #}

  {% if macro.overnight %}
  <section>
    <h2>
      🌙 간밤 해외 시장
      {% if macro.overnight_impact %}
      <span class="macro-mood {{ macro.overnight_impact }}">
        {% if macro.overnight_impact == 'positive' %}🟢 우호적
        {% elif macro.overnight_impact == 'negative' %}🔴 부담
        {% else %}🟡 혼조{% endif %}
      </span>
      {% endif %}
    </h2>
    <p class="section-sub">미국 증시 전일 종가 및 주요 원자재/환율</p>
    <div class="indicators">
      {% for ind in macro.overnight %}
      <div class="indicator {{ ind.impact or ind.direction or 'neutral' }}">
        <div class="name">{{ ind.name }}</div>
        <div class="value">{{ ind.value }}</div>
        {% if ind.change_abs or ind.change_pct %}
        <div class="change {{ ind.direction or '' }}">
          {% if ind.change_abs %}
          <span class="abs">{% if ind.direction == 'up' %}▲{% elif ind.direction == 'down' %}▼{% endif %} {{ ind.change_abs|replace('+','')|replace('-','') }}</span>
          {% endif %}
          {% if ind.change_pct %}<span class="pct">{{ ind.change_pct }}</span>{% endif %}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% macro sector_news_item(n) %}
    <li>
      <span class="news-dot {{ n.impact or 'neutral' }}"></span>
      <div class="news-body">
        <div class="news-title">
          {% if n.source and n.source.url %}
            <a href="{{ n.source.url }}" target="_blank" rel="noopener">{{ n.title }}</a>
          {% elif n.sources and n.sources[0].url %}
            <a href="{{ n.sources[0].url }}" target="_blank" rel="noopener">{{ n.title }}</a>
          {% else %}
            {{ n.title }}
          {% endif %}
        </div>
        <div class="news-meta">
          {% if n.time_ago %}<span class="time-ago">{{ n.time_ago }}</span>{% endif %}
          {% if n.source and n.source.title %}<span>· {{ n.source.title }}</span>
          {% elif n.sources %}{% for s in n.sources %}<span>· {{ s.title }}</span>{% endfor %}{% endif %}
          {% if n.impact %}<span class="impact {{ n.impact }}">{{ n.impact_label or n.impact }}</span>{% endif %}
        </div>
        {% if n.why_material %}<div class="why-material">📈 {{ n.why_material }}</div>{% endif %}
        {% if n.note %}<div class="news-note">{{ n.note }}</div>{% endif %}
      </div>
    </li>
  {% endmacro %}

  {% if sectors %}
  <section>
    <h2>🏭 섹터 흐름</h2>
    {% for sec in sectors %}
    <div class="sector-card {{ sec.impact or 'neutral' }}">
      <div class="sec-head">
        <div class="sec-title">
          {% if sec.emoji %}<span class="sec-emoji">{{ sec.emoji }}</span>{% endif %}
          {{ sec.name }}
        </div>
        {% if sec.impact %}
        <span class="macro-mood {{ sec.impact }}">
          {% if sec.impact == 'positive' %}🟢 우호
          {% elif sec.impact == 'negative' %}🔴 부담
          {% else %}🟡 혼조{% endif %}
        </span>
        {% endif %}
      </div>
      {% if sec.headline %}<div class="sec-headline">{{ sec.headline }}</div>
      {% elif sec.summary %}<div class="sec-headline">{{ sec.summary }}</div>
      {% endif %}

      {% if sec.news %}
      {% set preview = sec.news[:2] %}
      {% set rest    = sec.news[2:] %}
      <ul class="sec-news">
        {% for n in preview %}{{ sector_news_item(n) }}{% endfor %}
      </ul>
      {% if rest %}
      <details class="sec-more">
        <summary>더 보기 ({{ rest|length }}건)</summary>
        <ul class="sec-news">
          {% for n in rest %}{{ sector_news_item(n) }}{% endfor %}
        </ul>
      </details>
      {% endif %}
      {% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  <section>
    <h2>📈 종목별 <span class="section-sub" style="font-size: 13px; margin-left: 4px;">(클릭하면 상세 펼침)</span></h2>
    {% for stock in stocks %}
    <article class="stock">
      <details>
        <summary>
          <span class="name">{{ stock.name }}</span>
          <span class="code">{{ stock.code }}</span>
          {% if stock.news_count %}
          <span class="news-count-chip" title="오늘 새 뉴스 {{ stock.news_count }}건">🔥 {{ stock.news_count }}</span>
          {% endif %}
          {% if stock.price_change_display %}
          <span class="price-change {{ stock.price_direction }}" title="어제 종가 기준">{{ stock.price_change_display }}</span>
          {% endif %}
          {% if stock.recommendation %}
          <span class="rec {{ stock.recommendation }}">{{ stock.recommendation_label or stock.recommendation }}</span>
          {% endif %}
          {% if stock.result and stock.result.outcome and stock.result.outcome != 'n/a' %}
          <span class="outcome-badge {{ stock.result.outcome }}" title="아침 예측 대비 실제 결과">
            {% if stock.result.outcome == 'hit' %}✅{% elif stock.result.outcome == 'partial' %}🟡{% elif stock.result.outcome == 'miss' %}❌{% endif %}
            {% if stock.result.actual_change_pct is not none %}{{ '%+.2f'|format(stock.result.actual_change_pct) }}%{% endif %}
          </span>
          {% endif %}
          {% if stock.owners %}
          <span class="owner-chips">{{ owner_chips(stock.owners) }}</span>
          {% endif %}
        </summary>
        <div class="body">
          {% if stock.history and stock.history.sparkline_path %}
          <div class="price-context">
            <div class="spark-wrap">
              <svg class="spark {{ stock.history.sparkline_direction or 'flat' }}" viewBox="0 0 80 24" preserveAspectRatio="none">
                <path d="{{ stock.history.sparkline_path }}"/>
              </svg>
              <div class="spark-label">
                20일
                {% if stock.history.change_20d_pct is not none %}
                  {% if stock.history.change_20d_pct > 0 %}<span class="pos">+{{ '%.1f'|format(stock.history.change_20d_pct) }}%</span>
                  {% elif stock.history.change_20d_pct < 0 %}<span class="neg">{{ '%.1f'|format(stock.history.change_20d_pct) }}%</span>
                  {% else %}<span>0%</span>{% endif %}
                {% endif %}
              </div>
            </div>
            <div class="w52">
              <div class="w52-bar">
                {% if stock.history.pos_52w_pct is not none %}
                <div class="w52-pin" style="left: {{ stock.history.pos_52w_pct }}%" title="52주 범위 내 현재 위치"></div>
                {% endif %}
              </div>
              <div class="w52-labels">
                <span>저 {{ '{:,.0f}'.format(stock.history.fifty_two_week_low) if stock.history.fifty_two_week_low else '' }}</span>
                <span class="mid">
                  {% if stock.history.from_high_pct is not none %}
                    고점 대비 {% if stock.history.from_high_pct >= 0 %}+{% endif %}{{ '%.1f'|format(stock.history.from_high_pct) }}%
                  {% endif %}
                </span>
                <span>고 {{ '{:,.0f}'.format(stock.history.fifty_two_week_high) if stock.history.fifty_two_week_high else '' }}</span>
              </div>
            </div>
          </div>
          {% endif %}

          {# Trader morning digest: today's news goes first, decision block after #}
          {% if stock.news %}
          <div class="stock-news-block">
            <h4>📰 오늘의 뉴스 ({{ stock.news|length }}건, 최신순)</h4>
            {% set visible_news = stock.news[:5] %}
            {% set hidden_news  = stock.news[5:] %}
            <ul>
              {% for n in visible_news %}
              <li>
                <span class="news-dot {{ n.impact or 'neutral' }}"></span>
                <div class="news-body">
                  <div class="news-title">
                    {% if n.url or n.link %}
                    <a href="{{ n.url or n.link }}" target="_blank" rel="noopener">{{ n.title }}</a>
                    {% else %}{{ n.title }}{% endif %}
                  </div>
                  <div class="news-meta">
                    {% if n.time_ago %}<span class="time-ago">{{ n.time_ago }}</span>{% endif %}
                    {% if n.source %}<span>· {% if n.source is mapping %}{{ n.source.title }}{% else %}{{ n.source }}{% endif %}</span>{% endif %}
                    {% if n.impact %}<span class="impact {{ n.impact }}">{{ n.impact_label or n.impact }}</span>{% endif %}
                  </div>
                  {% if n.why_material %}<div class="why-material">📈 {{ n.why_material }}</div>{% endif %}
                </div>
              </li>
              {% endfor %}
            </ul>
            {% if hidden_news %}
            <details class="news-more">
              <summary>더 보기 ({{ hidden_news|length }}건)</summary>
              <ul>
                {% for n in hidden_news %}
                <li>
                  <span class="news-dot {{ n.impact or 'neutral' }}"></span>
                  <div class="news-body">
                    <div class="news-title">
                      {% if n.url or n.link %}
                      <a href="{{ n.url or n.link }}" target="_blank" rel="noopener">{{ n.title }}</a>
                      {% else %}{{ n.title }}{% endif %}
                    </div>
                    <div class="news-meta">
                      {% if n.time_ago %}<span class="time-ago">{{ n.time_ago }}</span>{% endif %}
                      {% if n.source %}<span>· {% if n.source is mapping %}{{ n.source.title }}{% else %}{{ n.source }}{% endif %}</span>{% endif %}
                      {% if n.impact %}<span class="impact {{ n.impact }}">{{ n.impact_label or n.impact }}</span>{% endif %}
                    </div>
                    {% if n.why_material %}<div class="why-material">📈 {{ n.why_material }}</div>{% endif %}
                  </div>
                </li>
                {% endfor %}
              </ul>
            </details>
            {% endif %}
          </div>
          {% endif %}

          {% if stock.news_sentiment or stock.overnight_signal or stock.priced_in is defined or stock.rationale %}
          <div class="decision-block">
            {% if stock.news_sentiment %}
            <div class="row"><span class="label">뉴스 톤</span><span class="value impact {{ stock.news_sentiment }}">{{ stock.news_sentiment_label or stock.news_sentiment }}</span>{% if stock.confidence %}<span class="confidence-chip {{ stock.confidence }}">신뢰 {{ stock.confidence_label or stock.confidence }}</span>{% endif %}</div>
            {% endif %}
            {% if stock.overnight_signal and stock.overnight_signal.direction %}
            <div class="row"><span class="label">간밤 신호</span>
              <span class="value overnight-badge {{ stock.overnight_signal.direction }}">
                {% if stock.overnight_signal.direction == 'up' %}▲{% elif stock.overnight_signal.direction == 'down' %}▼{% else %}—{% endif %}
                {{ stock.overnight_signal.label or stock.overnight_signal.direction }}
                {% if stock.overnight_signal.avg_pct is not none %} ({{ '%.2f'|format(stock.overnight_signal.avg_pct | abs) }}%){% endif %}
              </span>
              {% if stock.overnight_signal.proxies %}
              <span class="proxies">
                {% for p in stock.overnight_signal.proxies %}<span class="p {% if p.change_pct > 0 %}up{% elif p.change_pct < 0 %}down{% endif %}">{{ p.symbol }} {% if p.change_pct > 0 %}▲{% elif p.change_pct < 0 %}▼{% else %}—{% endif %} {{ '%.2f'|format(p.change_pct | abs) }}%</span>{% if not loop.last %} · {% endif %}{% endfor %}
              </span>
              {% endif %}
            </div>
            {% endif %}
            {% if stock.priced_in is defined %}
            <div class="row"><span class="label">뉴스 반영</span><span class="value">{% if stock.priced_in %}이미 어제 주가에 반영{% else %}아직 반영 안 됨 (신선함){% endif %}</span></div>
            {% endif %}
            {% if stock.rationale %}<div class="rationale">{{ stock.rationale }}</div>{% endif %}
          </div>
          {% endif %}

          {% if stock.result and stock.result.outcome and stock.result.outcome != 'n/a' %}
          <div class="session-result-block">
            <div class="sr-head">🏁 오늘 세션 결과 (NXT 마감 기준)</div>
            <div class="sr-row">
              <span>예측</span>
              <span class="rec {{ stock.recommendation }}">{{ stock.recommendation_label or stock.recommendation }}</span>
              <span class="sr-arrow">→</span>
              <span>실제</span>
              {% if stock.result.actual_change_pct is not none %}
              <span class="price-change {{ stock.result.actual_direction or 'flat' }}">{{ '%+.2f'|format(stock.result.actual_change_pct) }}%</span>
              {% endif %}
              <span class="outcome-badge {{ stock.result.outcome }}">
                {% if stock.result.outcome == 'hit' %}✅ 적중{% elif stock.result.outcome == 'partial' %}🟡 부분{% elif stock.result.outcome == 'miss' %}❌ 실패{% endif %}
              </span>
            </div>
            {% if stock.result.note %}<div class="sr-note">{{ stock.result.note }}</div>{% endif %}
          </div>
          {% endif %}

          {% if stock.summary %}<p class="stock-summary">{{ stock.summary }}</p>{% endif %}

          {% if stock.key_points %}
          <ul class="points">
            {% for pt in stock.key_points %}
            <li>
              <div class="point-title">
                <span class="text">{{ pt.point }}</span>
                {% if pt.impact %}<span class="impact {{ pt.impact }}">{{ pt.impact_label or pt.impact }}</span>{% endif %}
                {% if pt.time_ago %}<span class="time-ago">{{ pt.time_ago }}</span>{% endif %}
              </div>
              {% if pt.detail %}<div class="point-detail">{{ pt.detail }}</div>{% endif %}
              {% if pt.sources %}
              <div class="sources">
                {% for src in pt.sources %}<a href="{{ src.url }}" target="_blank" rel="noopener">{{ src.title }}</a>{% endfor %}
              </div>
              {% endif %}
            </li>
            {% endfor %}
          </ul>
          {% endif %}

          {% if stock.deep_dive %}
          <div class="deep-dive">
            <h4>🔬 심층 분석</h4>
            {% if stock.deep_dive.business %}
            <div class="dd-block">
              <div class="dd-label">주력 사업·제품</div>
              <div class="dd-body">{{ stock.deep_dive.business }}</div>
            </div>
            {% endif %}
            {% if stock.deep_dive.market %}
            <div class="dd-block">
              <div class="dd-label">시장성</div>
              <div class="dd-body">{{ stock.deep_dive.market }}</div>
            </div>
            {% endif %}
            {% if stock.deep_dive.competitors %}
            <div class="dd-block">
              <div class="dd-label">경쟁 구도</div>
              <div class="dd-body">
                {% if stock.deep_dive.competitors is string %}{{ stock.deep_dive.competitors }}
                {% else %}
                <div class="dd-tags">{% for c in stock.deep_dive.competitors %}<span class="dd-tag">{{ c }}</span>{% endfor %}</div>
                {% endif %}
              </div>
            </div>
            {% endif %}
            {% if stock.deep_dive.research_notes %}
            <div class="dd-block">
              <div class="dd-label">R&D / 논문·특허 동향</div>
              <div class="dd-body">{{ stock.deep_dive.research_notes }}</div>
            </div>
            {% endif %}
            {% if stock.deep_dive.risks %}
            <div class="dd-block">
              <div class="dd-label">리스크</div>
              <div class="dd-body">{{ stock.deep_dive.risks }}</div>
            </div>
            {% endif %}
            {% if stock.deep_dive.sources %}
            <div class="sources">
              {% for src in stock.deep_dive.sources %}<a href="{{ src.url }}" target="_blank" rel="noopener">{{ src.title }}</a>{% endfor %}
            </div>
            {% endif %}
          </div>
          {% endif %}

          {% if stock.disclosures %}
          <h4>공시</h4>
          <ul class="disclosures">
            {% for d in stock.disclosures %}
            <li><a href="{{ d.url }}" target="_blank" rel="noopener">{{ d.title }}</a>{% if d.date %}<span class="date">{{ d.date }}</span>{% endif %}</li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
      </details>
    </article>
    {% endfor %}
  </section>

  <footer>
    <div class="disclaimer">
      <strong>⚠️ 투자 유의:</strong> 본 리포트는 AI가 공개 뉴스·공시·웹 자료를 종합해 자동 생성한
      개인 참고용이며, 투자 자문·권유가 아닙니다. 투자 판단과 책임은 전적으로 본인에게 있습니다.
      '풀매수/매수/관망/매도/풀매도' 의견은 AI의 단기 뉴스 흐름 해석일 뿐이며, 종목의 내재가치나
      장기 전망을 반영하지 않습니다.
    </div>
    <p>k-ant-daily · 자동 생성 리포트 · <a href="https://github.com/yummyummyummy/k-ant-daily" target="_blank" rel="noopener">GitHub</a></p>
  </footer>
</main>

<script>
(function () {
  // ── CONFIGURE ME ────────────────────────────────────────────────
  // After deploying the Cloudflare Worker in ../worker/, paste its URL here.
  // Expected shape: https://<name>.<subdomain>.workers.dev/quote
  // Leave as "" to disable live polling (snapshot values render as-is).
  const QUOTE_API  = "https://k-ant-daily-quotes.yummyummyummy.workers.dev/quote";
  const TICKER_API = "https://k-ant-daily-quotes.yummyummyummy.workers.dev/ticker";
  const TICKER_ITEMS = ["KOSPI", "KOSDAQ", "USDKRW", "BTC", "ETH"];
  // ────────────────────────────────────────────────────────────────

  const POLL_MS = 60_000;
  const MARKET_OPEN_MIN  = 9 * 60;       // 09:00 KST
  const MARKET_CLOSE_MIN = 15 * 60 + 30; // 15:30 KST

  function kstNow() {
    // Build a KST wall-clock regardless of viewer timezone.
    const utc = Date.now() + new Date().getTimezoneOffset() * 60_000;
    return new Date(utc + 9 * 60 * 60_000);
  }

  function isMarketOpen() {
    const k = kstNow();
    const day = k.getDay(); // 0=Sun, 6=Sat
    if (day === 0 || day === 6) return false;
    const mins = k.getHours() * 60 + k.getMinutes();
    return mins >= MARKET_OPEN_MIN && mins < MARKET_CLOSE_MIN;
  }

  // The page is "live" (should poll for updates) only if its rendered date
  // matches today's KST date. Archive pages freeze their snapshot.
  function isLivePage() {
    const pageDate = document.body.dataset.date;
    if (!pageDate) return true; // fallback: behave as live if unmarked
    const k = kstNow();
    const todayKst = `${k.getFullYear()}-${String(k.getMonth() + 1).padStart(2, "0")}-${String(k.getDate()).padStart(2, "0")}`;
    return pageDate === todayKst;
  }

  function fmtKstTime(d) {
    const hh = String(d.getHours()).padStart(2, "0");
    const mm = String(d.getMinutes()).padStart(2, "0");
    const ss = String(d.getSeconds()).padStart(2, "0");
    return `${hh}:${mm}:${ss}`;
  }

  function fmtPrice(n) {
    if (n == null) return "";
    return Number(n).toLocaleString("ko-KR");
  }

  function fmtAbs(n, direction) {
    if (n == null) return "";
    const abs = Math.abs(Number(n));
    if (abs === 0) return "—";
    const num = abs.toLocaleString("ko-KR");
    if (direction === "up")   return "▲ " + num;
    if (direction === "down") return "▼ " + num;
    return num;
  }

  function fmtPct(n) {
    if (n == null) return "";
    const v = Number(n);
    const sign = v > 0 ? "+" : "";
    return sign + v.toFixed(2) + "%";
  }

  function setIndicator(state, text) {
    const el = document.getElementById("live-indicator");
    if (!el) return;
    el.classList.remove("live", "closed", "error");
    el.classList.add(state);
    el.textContent = text;
  }

  function applyQuote(card, q) {
    const quoteBox = card.querySelector(".quote");
    const priceEl  = card.querySelector(".price");
    const absEl    = card.querySelector(".abs");
    const pctEl    = card.querySelector(".pct");
    if (!quoteBox || !priceEl) return;

    const newPrice = fmtPrice(q.price);
    const priceChanged = priceEl.textContent.trim() !== newPrice;

    priceEl.textContent = newPrice;
    if (absEl) absEl.textContent = fmtAbs(q.change, q.direction);
    if (pctEl) pctEl.textContent = fmtPct(q.change_pct);

    // Update up/down/flat class on the quote container
    quoteBox.classList.remove("up", "down", "flat");
    quoteBox.classList.add(q.direction || "flat");

    // Flash the price cell on change
    if (priceChanged && q.direction && q.direction !== "flat") {
      const cls = q.direction === "up" ? "flash-up" : "flash-down";
      priceEl.classList.remove("flash-up", "flash-down");
      // Force reflow so the animation restarts
      void priceEl.offsetWidth;
      priceEl.classList.add(cls);
    }
  }

  function setTickerDelta(deltaEl, q) {
    deltaEl.classList.remove("up", "down", "flat");
    deltaEl.classList.add(q.direction || "flat");
    while (deltaEl.firstChild) deltaEl.removeChild(deltaEl.firstChild);
    if (q.change_abs) deltaEl.appendChild(document.createTextNode(q.change_abs));
    if (q.change_pct) {
      const pct = document.createElement("span");
      pct.className = "pct";
      pct.textContent = " " + q.change_pct;
      deltaEl.appendChild(pct);
    }
  }

  async function refreshTicker() {
    if (!TICKER_API) return;
    try {
      const url = TICKER_API + "?items=" + encodeURIComponent(TICKER_ITEMS.join(","));
      const res = await fetch(url, { cache: "no-store" });
      if (!res.ok) return;
      const data = await res.json();
      Object.entries(data).forEach(([key, q]) => {
        // Each ticker symbol appears twice in the DOM (duplicated for
        // seamless marquee loop) — update both.
        document.querySelectorAll(`.ticker-item[data-ticker="${key}"]`).forEach((item) => {
          const valEl   = item.querySelector(".value");
          const deltaEl = item.querySelector(".delta");
          if (valEl && q.value) valEl.textContent = q.value;
          if (deltaEl) setTickerDelta(deltaEl, q);
        });
      });
    } catch (err) {
      /* silent — keep snapshot */
    }
  }

  function reorderFriendCards(data) {
    const container = document.getElementById("friend-cards");
    if (!container) return;
    const cards = [...container.querySelectorAll(".friend-card[data-code]")];
    if (cards.length < 2) return;

    // Back off if the user is mid-interaction so a card doesn't move
    // under the cursor/finger.
    if (cards.some((c) => c.matches(":hover") || c.querySelector("details[open]") || c.querySelector(".owners-wrap.open"))) {
      return;
    }

    // Stable sort by live change_pct desc; missing quotes keep original rank.
    const withPct = cards.map((el, i) => ({
      el,
      code: el.dataset.code,
      pct: typeof data[el.dataset.code]?.change_pct === "number"
           ? data[el.dataset.code].change_pct : -Infinity,
      origIdx: i,
    }));
    withPct.sort((a, b) => b.pct - a.pct || a.origIdx - b.origIdx);

    // Only reshuffle if the top-3 order actually changed. Micro-wiggles in
    // lower ranks stay put — the grid shouldn't bounce every poll.
    const top3Before = cards.slice(0, 3).map((c) => c.dataset.code).join(",");
    const top3After  = withPct.slice(0, 3).map((x) => x.code).join(",");
    if (top3Before === top3After) return;

    // FLIP: capture first position
    const firstRects = new Map(cards.map((c) => [c, c.getBoundingClientRect()]));

    // Reorder DOM (append of an existing node moves it — no duplication)
    withPct.forEach((x) => container.append(x.el));

    const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduceMotion) return;

    // FLIP: measure delta, snap back, then animate to natural position
    withPct.forEach((x) => {
      const first = firstRects.get(x.el);
      const last  = x.el.getBoundingClientRect();
      const dx = first.left - last.left;
      const dy = first.top  - last.top;
      if (!dx && !dy) return;
      x.el.style.transition = "transform 0s";
      x.el.style.transform  = `translate(${dx}px, ${dy}px)`;
      requestAnimationFrame(() => {
        x.el.style.transition = "transform 0.35s cubic-bezier(0.2, 0, 0.1, 1)";
        x.el.style.transform  = "";
      });
    });
  }

  function updateCoffeeBanner(cards, data) {
    const banner = document.querySelector(".coffee-banner");
    if (!banner) return;
    const headline = banner.querySelector(".headline");
    const sub      = banner.querySelector(".sub");

    // Build entries from the DOM so ownership/name info stays server-rendered
    // (single source of truth); the Worker just supplies live numbers.
    const entries = [];
    cards.forEach((card) => {
      const q = data[card.dataset.code];
      if (!q || typeof q.change_pct !== "number") return;
      const name = card.querySelector(".stock-name")?.textContent?.trim() || "";
      // Only pick up chips inside the popover (which is the full owner list).
      // Falls back to top-level chips when there's no popover (single-owner card).
      const pop = card.querySelector(".owner-popover");
      const chipScope = pop || card.querySelector(".owners-wrap") || card.querySelector(".owners");
      const rawChips = chipScope ? [...chipScope.querySelectorAll(".owner-chip")] : [];
      const owners = rawChips
        .filter((el) => !el.classList.contains("owner-more"))
        .map((el) => el.textContent.replace("👤", "").trim())
        .filter(Boolean);
      entries.push({ name, owners, pct: q.change_pct });
    });

    const positives = entries.filter((e) => e.pct > 0);
    positives.sort((a, b) => b.pct - a.pct);
    const top = positives[0];

    if (top) {
      banner.classList.remove("none");
      if (headline) {
        headline.textContent = "";
        headline.append("☕ 오늘 커피는 ");
        const strong = document.createElement("strong");
        strong.textContent = top.owners.join("·");
        headline.append(strong, "님이!");
      }
      if (sub) {
        const sign = top.pct > 0 ? "+" : "";
        sub.textContent = `${top.name} ${sign}${top.pct.toFixed(2)}% — 친구 보유 종목 중 최고 상승`;
      }
    } else {
      banner.classList.add("none");
      if (headline) headline.textContent = "☕ 오늘 커피는 각자 사기";
      if (sub) sub.textContent = "친구 보유 종목 중 상승 종목 없음";
    }
  }

  async function refreshQuotes() {
    if (!QUOTE_API) return;
    const cards = document.querySelectorAll(".friend-card[data-code]");
    if (!cards.length) return;
    const codes = [...cards].map((el) => el.dataset.code);
    try {
      const url = QUOTE_API + "?codes=" + encodeURIComponent(codes.join(","));
      const res = await fetch(url, { cache: "no-store" });
      if (!res.ok) throw new Error("status " + res.status);
      const data = await res.json();
      let applied = 0;
      cards.forEach((card) => {
        const q = data[card.dataset.code];
        if (q) { applyQuote(card, q); applied += 1; }
      });
      if (applied > 0) {
        updateCoffeeBanner(cards, data);
        reorderFriendCards(data);
        setIndicator("live", "🟢 Live · 업데이트 " + fmtKstTime(kstNow()));
      }
    } catch (err) {
      setIndicator("error", "⚠️ 실시간 업데이트 실패 (스냅샷 표시) · " + fmtKstTime(kstNow()));
    }
  }

  // Owner popover tap toggle — needed on touch devices where :hover isn't reliable.
  // Also closes any other open popover when one is opened.
  document.addEventListener("click", (e) => {
    const wrap = e.target.closest(".owners-wrap");
    document.querySelectorAll(".owners-wrap.open").forEach((el) => {
      if (el !== wrap) el.classList.remove("open");
    });
    if (wrap && wrap.querySelector(".owner-popover")) {
      // Don't toggle if the user clicked a link/button inside; only when
      // the target was the wrap itself, the primary chip, or the +N chip.
      const t = e.target;
      if (t === wrap || t.classList.contains("owner-chip")) {
        wrap.classList.toggle("open");
      }
    }
  });

  function init() {
    // Archive pages (rendered date ≠ today) freeze — no polling, no ticker
    // refresh. The snapshot baked into the HTML is the historical truth for
    // that day and mustn't be overwritten by today's live prices.
    if (!isLivePage()) {
      setIndicator("closed", "📁 아카이브 — " + (document.body.dataset.date || "") + " 스냅샷");
      return;
    }

    // Ticker (indices + FX + crypto) polls 24/7 on the live page — crypto
    // trades on weekends, and FX/indices just stop updating cleanly outside
    // market hours.
    if (TICKER_API) {
      refreshTicker();
      setInterval(refreshTicker, POLL_MS);
    }

    if (!QUOTE_API) {
      setIndicator("closed", "⏸ 실시간 업데이트 비활성 (스냅샷)");
      return;
    }
    if (!isMarketOpen()) {
      setIndicator("closed", "⏸ 장 마감 — 종가 표시 중");
      return;
    }
    refreshQuotes();
    setInterval(refreshQuotes, POLL_MS);
    // Re-check market-close boundary every minute; stop friend-stock polling after 15:30.
    setInterval(() => {
      if (!isMarketOpen()) {
        setIndicator("closed", "⏸ 장 마감 — 종가 표시 중");
      }
    }, 60_000);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>
</body>
</html>
