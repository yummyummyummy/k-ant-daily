{#- Shared theme tokens + universal reset. Include inside <style>…</style>.
    Single source of truth for colors, so the four public pages (report /
    accuracy / accuracy_day / archive) stay visually aligned. Unused tokens
    on any given page are harmless; they just aren't referenced. -#}
  :root {
    --fg: #0f172a;
    --muted: #64748b;
    --bg: #ffffff;
    --accent: #0f766e;
    --border: #e2e8f0;
    --card: #f8fafc;
    /* 한국 주식 관행: 상승=빨강 / 하락=파랑 */
    --pos: #dc2626;     --pos-bg: rgba(220,38,38,0.08);
    --neg: #2563eb;     --neg-bg: rgba(37,99,235,0.08);
    --partial: #d97706; --partial-bg: rgba(245,158,11,0.15);
    --neu: #6b7280;     --neu-bg: rgba(107,114,128,0.08);
    --good: #16a34a;    --good-bg: rgba(22,163,74,0.08);
    --bad:  #b91c1c;    --bad-bg:  rgba(185,28,28,0.08);
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --fg: #e2e8f0;
      --muted: #94a3b8;
      --bg: #0f172a;
      --accent: #5eead4;
      --border: #1e293b;
      --card: #1e293b;
      --pos: #f87171;  --pos-bg: rgba(248,113,113,0.12);
      --neg: #60a5fa;  --neg-bg: rgba(96,165,250,0.12);
      --neu: #94a3b8;  --neu-bg: rgba(148,163,184,0.12);
      --good: #4ade80; --good-bg: rgba(74,222,128,0.12);
      --bad:  #f87171; --bad-bg:  rgba(248,113,113,0.12);
    }
  }
  * { box-sizing: border-box; }

  /* 하이라이터 — macro.summary · rationale 등 agent 가 `**...**` 로 감싼 구절이
     이 스타일로 렌더된다. 장중 변동성 핵심 변수나 주요 예측 문구를 시각적으로
     부각하는 용도. 내용은 `highlight` Jinja 필터가 생성. */
  mark.driver {
    background: rgba(250, 204, 21, 0.35);
    color: inherit;
    font-weight: 700;
    padding: 1px 4px;
    border-radius: 3px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  @media (prefers-color-scheme: dark) {
    mark.driver {
      background: rgba(250, 204, 21, 0.22);
      color: var(--fg);
    }
  }
