<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.yummyummyummy.k-ant-daily.check-results</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/woong/projects/k-ant-daily/scripts/launchd/run-check-results.sh</string>
    </array>

    <!-- Every 30 minutes. The wrapper cheap-gates (scripts/pending_results.py)
         so off-event ticks exit in milliseconds without git or Claude. -->
    <key>StartInterval</key>
    <integer>1800</integer>

    <key>RunAtLoad</key><false/>

    <key>StandardOutPath</key>
    <string>/Users/woong/Library/Logs/k-ant-daily/launchd-check-results.out</string>
    <key>StandardErrorPath</key>
    <string>/Users/woong/Library/Logs/k-ant-daily/launchd-check-results.err</string>

    <key>ProcessType</key><string>Background</string>
    <key>Nice</key><integer>10</integer>
</dict>
</plist>
