<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.yummyummyummy.k-ant-daily.review</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/woong/projects/k-ant-daily/scripts/launchd/run-review.sh</string>
    </array>

    <!-- 20:10 on weekdays (Mon-Fri), 10 min after NXT close. Local timezone
         (Asia/Seoul) assumed. -->
    <key>StartCalendarInterval</key>
    <array>
        <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>20</integer><key>Minute</key><integer>10</integer></dict>
        <dict><key>Weekday</key><integer>2</integer><key>Hour</key><integer>20</integer><key>Minute</key><integer>10</integer></dict>
        <dict><key>Weekday</key><integer>3</integer><key>Hour</key><integer>20</integer><key>Minute</key><integer>10</integer></dict>
        <dict><key>Weekday</key><integer>4</integer><key>Hour</key><integer>20</integer><key>Minute</key><integer>10</integer></dict>
        <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>20</integer><key>Minute</key><integer>10</integer></dict>
    </array>

    <key>RunAtLoad</key><false/>

    <key>StandardOutPath</key>
    <string>/Users/woong/Library/Logs/k-ant-daily/launchd-review.out</string>
    <key>StandardErrorPath</key>
    <string>/Users/woong/Library/Logs/k-ant-daily/launchd-review.err</string>

    <key>ProcessType</key><string>Background</string>
</dict>
</plist>
